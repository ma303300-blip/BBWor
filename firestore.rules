rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /managers/{uid} {
      allow read, write: if request.auth != null;
    }

    match /employees/{empId} {
      allow read, write: if request.auth != null;
    }

    match /constraints/{docId}              { allow read, write: if request.auth != null; }
    match /schedules/{docId}                { allow read, write: if request.auth != null; }
    match /checklist_items/{docId}          { allow read, write: if request.auth != null; }
    match /checklist_completions/{docId}    { allow read, write: if request.auth != null; }
    match /shift_submissions/{docId}        { allow read, write: if request.auth != null; }
    match /shift_approvals/{docId}          { allow read, write: if request.auth != null; }
    match /checklist_item_approvals/{docId} { allow read, write: if request.auth != null; }
    match /daily_goal_submissions/{docId}   { allow read, write: if request.auth != null; }
    match /segment_tracker/{docId}          { allow read, write: if request.auth != null; }
    match /monthly_goals/{docId}            { allow read, write: if request.auth != null; }
    match /daily_sales/{docId}              { allow read, write: if request.auth != null; }
    match /security_procedures/{docId}      { allow read, write: if request.auth != null; }
    match /competitions/{docId}             { allow read, write: if request.auth != null; }
    match /competition_joins/{docId}        { allow read, write: if request.auth != null; }
    match /constraint_resets/{docId}        { allow read, write: if request.auth != null; }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
